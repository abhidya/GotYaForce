{
  "name": "game",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Gotcha Force browser app — Vite + TypeScript + three.js runtime.",
  "scripts": {
    "dev": "vite",
    "dev:server": "node server.mjs",
    "dev:server:watch": "node --watch server.mjs",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit"
  },
  "dependencies": {
    "three": "^0.169.0",
    "ws": "^8.21.0",
    "@gf/assets": "workspace:*",
    "@gf/audio": "workspace:*",
    "@gf/combat": "workspace:*",
    "@gf/core": "workspace:*",
    "@gf/formats": "workspace:*",
    "@gf/missions": "workspace:*",
    "@gf/render": "workspace:*"
  },
  "devDependencies": {
    "@types/three": "^0.169.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
