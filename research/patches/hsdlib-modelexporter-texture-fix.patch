         /// 
         /// </summary>
         /// <returns></returns>
+        /// <summary>
+        /// FNV-1a over raw image bytes; used for stable content-addressed texture names.
+        /// </summary>
+        private static uint HashImageBytes(byte[] data)
+        {
+            const uint FNV_OFFSET_BASIS = 0x811C9DC5;
+            const uint FNV_PRIME = 0x01000193;
+            uint hash = FNV_OFFSET_BASIS;
+            foreach (byte b in data)
+            {
+                hash ^= b;
+                hash *= FNV_PRIME;
+            }
+            return hash;
+        }
